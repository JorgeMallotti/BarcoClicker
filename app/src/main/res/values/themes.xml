<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PildoraClicker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorOnBackground">@color/brand_text</item>
        <item name="colorOnSurface">@color/brand_text</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:textColor">@color/brand_text</item>
        <item name="android:textColorPrimary">@color/brand_text</item>
        <item name="android:textColorSecondary">@color/brand_text</item>
        <item name="android:textColorTertiary">@color/brand_text</item>
        <item name="android:windowBackground">@color/brand_background</item>
        <!-- Customize your theme here. -->
    </style>
</resources>