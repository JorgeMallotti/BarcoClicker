<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_light">

    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textStyle="bold"
        android:textSize="20sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvLanguageLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_language_label"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinLanguage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvVolumeLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_volume_label"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvVolumeValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_volume_value_default"
        android:layout_marginBottom="8dp" />

    <SeekBar
        android:id="@+id/sbMusicVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100" />

</LinearLayout>
