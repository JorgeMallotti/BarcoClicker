<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#E3F2FD">

    <!-- Score -->
    <TextView
        android:id="@+id/tvScoreFights"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/score_label"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvRunTimerFights"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:text="@string/run_timer_default"
        android:textSize="18sp" />

    <!-- Combat Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Player -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvPlayerHealthLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tu_label" />

            <ProgressBar
                android:id="@+id/pbPlayerHealth"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:progressDrawable="@android:drawable/progress_horizontal" />

            <ImageView
                android:id="@+id/ivPlayer"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:src="@drawable/player" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vs_label"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Enemy -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Boss Warning Text -->
            <TextView
                android:id="@+id/tvBossWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/boss_preparing_special"
                android:textColor="@color/warning_text"
                android:textStyle="bold"
                android:textSize="18sp"
                android:visibility="gone"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvEnemyHealthLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enemy_health_default" />

            <ProgressBar
                android:id="@+id/pbEnemyHealth"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:progressDrawable="@android:drawable/progress_horizontal" />

            <ImageView
                android:id="@+id/ivEnemy"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:src="@drawable/fungo_idle" />
        </LinearLayout>
    </LinearLayout>

    <!-- Turn Menu -->
    <LinearLayout
        android:id="@+id/layoutCombatMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_attack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_attack"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_defend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_defend"/>
    </LinearLayout>

    <!-- Upgrades Section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAttack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_attack_label" />
            <Button
                android:id="@+id/btnUpgradeAttack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/upgrade_attack" />

            <TextView
                android:id="@+id/tvDefense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_defense_label" />
            <Button
                android:id="@+id/btnUpgradeDefense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/upgrade_defense" />

            <TextView
                android:id="@+id/tvHealth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_health_label" />
            <Button
                android:id="@+id/btnUpgradeHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/upgrade_health" />

            <TextView
                android:id="@+id/tvAGI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_agi_label" />
            <Button
                android:id="@+id/btnUpgradeAGI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/upgrade_agi" />

            <TextView
                android:id="@+id/tvLucky"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_lucky_label" />
            <Button
                android:id="@+id/btnUpgradeLucky"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/upgrade_lucky" />

            <Button
                android:id="@+id/btn_back"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_back"
                android:layout_marginTop="16dp"
                android:backgroundTint="#9E9E9E"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>